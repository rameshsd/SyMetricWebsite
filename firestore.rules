
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'rameshdodamani22@gmail.com';
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
      allow list: if isAdmin();
    }

    match /communityPosts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    match /websiteVisits/{visitId} {
      allow create: if true;
      allow read, list: if isAdmin();
    }

    match /demoRequests/{requestId} {
      allow create: if true;
      allow read, update, delete, list: if isAdmin();
    }

    match /contactFormSubmissions/{submissionId} {
        allow create: if true;
        allow read, update, delete, list: if isAdmin();
    }

    match /pages/{pageId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /pageContent/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /jobOpenings/{jobId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /jobApplications/{applicationId} {
      allow create: if true;
      allow read, list: if isAdmin();
    }

    match /newsItems/{newsItemId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /calendarEvents/{eventId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /configuration/{configId} {
        // WARNING: Allowing public read access to SMTP configuration is a major security risk.
        // This is done to meet the requirement of a UI-only configuration without manual steps.
        // It is strongly recommended to use environment variables instead.
        allow read: if true; 
        allow write: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }
  }
}
    